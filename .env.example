# Base URL for file serving (without trailing slash)
URL=http://localhost:3060

# Admin credentials for basic auth (hash password with: php -r "echo password_hash('your_password', PASSWORD_BCRYPT);")
ADMIN_USER=admin
ADMIN_PASS=$2y$10$your_bcrypt_hashed_password_here

# CSRF secret (generate with: php -r "echo bin2hex(random_bytes(32));")
CSRF_SECRET=your_64_char_hex_secret_here

# Max file size in bytes (10MB default)
MAX_SIZE=10485760

# Allowed MIME types (comma-separated, for reference only - configured in config.php)
# image/jpeg,image/png,image/webp,application/pdf
